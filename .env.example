# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://devops_user:CHANGE_ME@localhost:5432/devops_tracker"

# ─── NextAuth / Auth.js ───────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────
# Buat di: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── App Config ───────────────────────────────────────────────
# Domain email yang boleh login. Satu atau beberapa dipisah koma (ALLOWED_EMAIL_DOMAIN dan/atau ALLOWED_EMAIL_DOMAINS).
# Contoh: ALLOWED_EMAIL_DOMAIN="gmv.media,gmvisual.id,sent.tv"
ALLOWED_EMAIL_DOMAIN="yourcompany.com"
# ALLOWED_EMAIL_DOMAINS="extra.com"

# Email ini otomatis jadi Super Admin saat pertama kali login
SUPER_ADMIN_EMAIL="admin@yourcompany.com"

# Masa berlaku sesi login (detik). Setelah habis, user harus login lagi. Default 28800 = 8 jam.
SESSION_MAX_AGE_SECONDS="28800"

# ─── Cron (daily monitoring 2x: 11–12 & 20–21 WIB) ──────────
# Generate: openssl rand -base64 32
CRON_SECRET="CHANGE_ME_GENERATE_WITH_OPENSSL"
# URL publik app (sama dengan NEXTAUTH_URL di produksi), dipakai GitHub Actions cron
# APP_URL="https://your-domain.com"

# ─── CloudFront (opsional) ────────────────────────────────────
# Kredensial diatur lewat UI admin (/cloudfront → tab Konfigurasi AWS), bukan .env.
# IAM user: minimal permission cloudfront:CreateInvalidation untuk distribution yang dipakai.
