generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  image            String?
  role             Role              @default(MEMBER)
  /// Super Admin menyetujui sebelum user baru bisa mengakses dashboard. Default DB true agar user lama aman; user baru di-set false lewat event createUser.
  accountApproved  Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts        Account[]
  activities      Activity[]
  sessions        Session[]
  logbookEntries  LogbookEntry[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String?
  url          String?
  repoUrl      String?
  category     String?
  management   String?
  status       String        @default("ACTIVE")
  platform     String[]
  webBasedApp  String        @default("Yes")
  costPerMonth String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activities   Activity[]
  docs         Doc[]
  tools        ProjectTool[]
  infras       ProjectInfra[]
}

model ProjectInfra {
  id           String   @id @default(cuid())
  projectId    String
  sortOrder    Int      @default(0)
  envName      String
  targetGroup  String?
  loadBalancer String?
  serverIp     String?
  hosting      String[]
  cdn          String[]
  databases    String[]
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, envName])
  @@index([projectId])
}

model Tool {
  id          String        @id @default(cuid())
  name        String
  category    String
  version     String?
  description String?
  docsUrl     String?
  logoUrl     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  projects    ProjectTool[]
}

model ProjectTool {
  id        String   @id @default(cuid())
  projectId String
  toolId    String
  version   String?
  config    Json?
  notes     String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([projectId, toolId])
}

model Doc {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  tags      String[]
  projectId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Activity {
  id         String   @id @default(cuid())
  action     String
  details    String?
  userId     String?
  projectId  String?
  ipAddress  String?  @db.VarChar(64)
  userAgent  String?  @db.VarChar(512)
  createdAt  DateTime @default(now())
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

/// Catatan aktivitas DevOps per minggu ISO (bisa diisi oleh seluruh tim).
model LogbookEntry {
  id         String   @id @default(cuid())
  userId     String
  isoYear    Int
  isoWeek    Int
  category   String
  title      String
  body       String   @db.Text
  // Waktu kejadian yang dilaporkan (boleh beda dari waktu entri dibuat).
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isoYear, isoWeek])
  @@index([occurredAt])
}

/// Konfigurasi Cloudflare (satu baris). Zone ID & token disimpan dari UI admin.
model CloudflareAppConfig {
  id        String   @id @default("default")
  zoneId    String   @default("")
  apiToken  String   @default("") @db.Text
  updatedAt DateTime @updatedAt
}

/// Preset body JSON purge (miri koleksi Postman).
model PurgePreset {
  id        String   @id @default(cuid())
  name      String
  bodyJson  String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  MEMBER
}

